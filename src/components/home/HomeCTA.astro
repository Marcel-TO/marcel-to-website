---
import Link from '@/components/Link.astro'
import { SOCIAL_LINKS, ICON_MAP } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<section class="mx-auto w-full max-w-5xl px-4 py-20 sm:py-28">
  <div
    class="relative overflow-hidden rounded-3xl border border-white/10 px-6 py-16 text-center sm:px-12 sm:py-20"
    data-reveal
  >
    {/* Brand backdrop */}
    <div class="absolute inset-0 -z-10 cta-bg"></div>
    <div
      class="absolute -top-1/3 left-1/2 -z-10 h-[50vh] w-[50vh] -translate-x-1/2 rounded-full blur-[120px]"
      style="background: radial-gradient(circle, rgba(255,77,109,0.35), transparent 70%);"
    >
    </div>

    <p class="mb-4 text-xs font-semibold tracking-[0.25em] text-white/60 uppercase">
      Get in touch
    </p>
    <h2
      class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-balance text-white sm:text-4xl md:text-5xl"
    >
      Let's build something worth remembering.
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-white/60 sm:text-lg">
      Have an idea, a question, or just want to say hi? My inbox and DMs are
      always open — let's talk code, data, or music.
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <Link
        href="/about"
        class="inline-flex items-center gap-2 rounded-full bg-white px-7 py-3 text-sm font-semibold text-neutral-900 transition-transform duration-300 hover:scale-[1.03]"
      >
        <Icon name="lucide:user" class="size-4" />
        More about me
      </Link>
      {
        SOCIAL_LINKS.map((link) => (
          <Link
            href={link.href}
            external
            aria-label={link.label}
            class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10"
          >
            <Icon name={ICON_MAP[link.label] ?? 'lucide:link'} class="size-4" />
            {link.label}
          </Link>
        ))
      }
      <Link
        href="/rss.xml"
        aria-label="RSS feed"
        class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:border-white/40 hover:bg-white/10"
      >
        <Icon name="lucide:rss" class="size-4" />
        RSS
      </Link>
    </div>
  </div>
</section>

<style>
  .cta-bg {
    background:
      radial-gradient(
        ellipse 90% 80% at 50% 0%,
        rgba(153, 0, 51, 0.6),
        transparent 70%
      ),
      linear-gradient(160deg, #12060c 0%, #0b0509 100%);
  }
</style>
