---
import { Icon } from 'astro-icon/components'

const facets = [
  {
    icon: 'lucide:file-chart-pie',
    title: 'Data Engineer',
    desc: 'Designing pipelines that turn raw data into decisions.',
  },
  {
    icon: 'lucide:code',
    title: 'Programmer',
    desc: 'Shipping clean, open-source software across the stack.',
  },
  {
    icon: 'lucide:gamepad-2',
    title: 'Gamer',
    desc: 'From chess to the latest titles - always up for a challenge.',
  },
  {
    icon: 'lucide:guitar',
    title: 'Musician',
    desc: 'The first listener of every composition is the composer.',
  },
]
---

<section
  id="intro"
  class="mx-auto w-full max-w-5xl scroll-mt-24 px-4 py-20 sm:py-28"
>
  <div class="mx-auto max-w-2xl text-center" data-reveal>
    <p
      class="text-brand mb-4 text-xs font-semibold tracking-[0.25em] uppercase"
    >
      Who I am
    </p>
    <h2
      class="text-3xl font-bold tracking-tight text-balance sm:text-4xl md:text-5xl"
    >
      I build things at the intersection of
      <span class="text-brand">data</span>, <span class="text-brand">code</span>
      and <span class="text-brand">curiosity</span>.
    </h2>
    <p
      class="text-muted-foreground mx-auto mt-6 max-w-xl text-base leading-relaxed sm:text-lg"
    >
      Always chasing the next challenge - whether that's a gnarly data problem,
      a new language, or a side project that refuses to leave my head.
    </p>
  </div>

  <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      facets.map((f, i) => (
        <div
          class="group border-border bg-secondary/30 hover:border-brand/40 hover:bg-secondary/60 relative overflow-hidden rounded-2xl border p-6 transition-all duration-300 hover:-translate-y-1"
          data-reveal
          style={`--reveal-delay: ${i * 90}ms;`}
        >
          <div class="from-brand/10 pointer-events-none absolute -top-8 -right-8 h-24 w-24 rounded-full bg-linear-to-br to-transparent opacity-0 blur-xl transition-opacity duration-300 group-hover:opacity-100" />
          <div class="bg-brand/10 text-brand mb-4 flex size-11 items-center justify-center rounded-xl transition-transform duration-300 group-hover:scale-110">
            <Icon name={f.icon} class="size-5" />
          </div>
          <h3 class="mb-1.5 text-lg font-semibold">{f.title}</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))
    }
  </div>
</section>
