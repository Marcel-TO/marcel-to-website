---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import MobileMenu from '@/components/ui/mobile-menu'
import { NAV_LINKS, SITE } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<div class="page-frame">
  {/* ---------- Bezel matte with rounded window cut-out ---------- */}
  <div class="pf-hole" aria-hidden="true"></div>

  {
    /* ---------- SVG frame: bezel fill + one continuous carved border ---------- */
  }
  <svg class="pf-svg" aria-hidden="true" preserveAspectRatio="none">
    <path class="pf-fill" fill-rule="evenodd"></path>
    <path class="pf-stroke"></path>
  </svg>

  {/* ---------- Carved logo tab (left) ---------- */}
  <Link href="/" aria-label={SITE.title} class="pf-tab pf-tab-logo">
    <Icon name="logo" size={40} class="text-foreground" />
  </Link>

  {/* ---------- Carved nav tab (center) ---------- */}
  <nav class="pf-tab pf-tab-nav" aria-label="Primary">
    {
      NAV_LINKS.map((item) => (
        <Link
          href={item.href}
          class="text-foreground/60 hover:bg-foreground/10 hover:text-foreground rounded-full px-3.5 py-1.5 text-sm font-medium capitalize transition-colors"
        >
          {item.label}
        </Link>
      ))
    }
  </nav>

  {/* ---------- Carved actions tab (right) ---------- */}
  <div class="pf-tab pf-tab-actions">
    <ThemeToggle />
    <div class="sm:hidden">
      <MobileMenu client:load />
    </div>
  </div>
</div>

<style>
  .page-frame {
    --bezel: var(--background);
    --pf-border: color-mix(in oklab, var(--foreground) 24%, transparent);
  }

  /* Invisible anchor - used only to measure the window rectangle in JS. */
  .pf-hole {
    position: fixed;
    top: var(--pf-bar-h);
    left: var(--pf-frame);
    right: var(--pf-frame);
    bottom: var(--pf-frame);
    border-radius: var(--pf-win-r);
    pointer-events: none;
    z-index: -1;
  }

  /* Fixed overlay that fills the bezel AND strokes the full carved border.
     Both share the same contour path, so fill and border align perfectly. */
  .pf-svg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 60;
  }
  .pf-fill {
    fill: var(--bezel);
  }
  .pf-stroke {
    fill: none;
    stroke: var(--pf-border);
    stroke-width: 1.5;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  /* ---------- Carved tabs (content holders; the bezel is drawn by the SVG) ---------- */
  .pf-tab {
    position: fixed;
    top: 0;
    height: var(--pf-logo-h);
    display: flex;
    align-items: center;
    justify-content: center;
    /* Push content up so it centres within the top bar. */
    padding-bottom: calc(var(--pf-logo-h) - var(--pf-bar-h));
    box-sizing: border-box;
    z-index: 62;
  }

  /* Left - logo */
  .pf-tab-logo {
    left: var(--pf-logo-x);
    width: var(--pf-logo-w);
  }

  /* Center - navigation (hidden on mobile) */
  .pf-tab-nav {
    left: 50%;
    transform: translateX(-50%);
    display: none;
    gap: 0.25rem;
    padding-inline: 0.6rem;
  }
  @media (min-width: 640px) {
    .pf-tab-nav {
      display: flex;
    }
  }

  /* Right - theme toggle / mobile menu */
  .pf-tab-actions {
    right: var(--pf-logo-x);
    gap: 0.5rem;
    padding-inline: 0.85rem;
  }
</style>

<script>
  // Build the frame as a single continuous contour: the window rounded-rect
  // whose top edge dips up-and-over each tab (concave fillets + rounded tab
  // corners). The fill path is the viewport rect minus this contour (even-odd);
  // the stroke path is the contour alone, giving one unbroken carved border.
  function buildFrame() {
    const svg = document.querySelector<SVGSVGElement>('.pf-svg')
    const hole = document.querySelector<HTMLElement>('.pf-hole')
    if (!svg || !hole) return
    const fill = svg.querySelector<SVGPathElement>('.pf-fill')
    const stroke = svg.querySelector<SVGPathElement>('.pf-stroke')
    if (!fill || !stroke) return

    const de = document.documentElement
    const W = de.clientWidth
    const H = de.clientHeight
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`)

    const rootStyle = getComputedStyle(de)
    const rem = parseFloat(rootStyle.fontSize) || 16
    const v = (name: string) => {
      const s = rootStyle.getPropertyValue(name).trim()
      return s.endsWith('rem') ? parseFloat(s) * rem : parseFloat(s)
    }
    const R = v('--pf-win-r')
    const F = v('--pf-fillet')
    const T = v('--pf-tab-r')

    const hr = hole.getBoundingClientRect()
    const L = hr.left
    const Tp = hr.top
    const Rt = hr.right
    const Bt = hr.bottom

    const tabs = Array.from(document.querySelectorAll<HTMLElement>('.pf-tab'))
      .map((el) => el.getBoundingClientRect())
      .filter((r) => r.width > 0 && r.height > 0)
      .sort((a, b) => a.left - b.left)

    let d = `M ${L + R} ${Tp}`
    for (const t of tabs) {
      const tl = t.left
      const tr = t.right
      const tb = t.bottom
      const prot = tb - Tp // tab protrusion depth below the window's top edge
      let f = F
      let cr = Math.min(T, (tr - tl) / 2)
      // The concave fillet and the rounded tab corner share the tab side. If
      // together they exceed the protrusion depth, the side would invert and
      // draw a stray vertical line - so shrink both to fit and meet cleanly.
      if (f + cr > prot) {
        const k = prot / (f + cr)
        f *= k
        cr *= k
      }
      d += ` L ${tl - f} ${Tp}`
      d += ` A ${f} ${f} 0 0 1 ${tl} ${Tp + f}` // left concave fillet
      d += ` L ${tl} ${tb - cr}`
      d += ` A ${cr} ${cr} 0 0 0 ${tl + cr} ${tb}` // bottom-left tab corner
      d += ` L ${tr - cr} ${tb}`
      d += ` A ${cr} ${cr} 0 0 0 ${tr} ${tb - cr}` // bottom-right tab corner
      d += ` L ${tr} ${Tp + f}`
      d += ` A ${f} ${f} 0 0 1 ${tr + f} ${Tp}` // right concave fillet
    }
    d += ` L ${Rt - R} ${Tp}`
    d += ` A ${R} ${R} 0 0 1 ${Rt} ${Tp + R}` // top-right window corner
    d += ` L ${Rt} ${Bt - R}`
    d += ` A ${R} ${R} 0 0 1 ${Rt - R} ${Bt}` // bottom-right
    d += ` L ${L + R} ${Bt}`
    d += ` A ${R} ${R} 0 0 1 ${L} ${Bt - R}` // bottom-left
    d += ` L ${L} ${Tp + R}`
    d += ` A ${R} ${R} 0 0 1 ${L + R} ${Tp}` // top-left
    d += ' Z'

    stroke.setAttribute('d', d)
    fill.setAttribute('d', `M 0 0 L ${W} 0 L ${W} ${H} L 0 ${H} Z ${d}`)
  }

  const schedule = () => requestAnimationFrame(buildFrame)
  schedule()
  window.addEventListener('resize', schedule)
  document.addEventListener('astro:page-load', schedule)
  document.addEventListener('astro:after-swap', schedule)
  document.fonts?.ready?.then(schedule)
  // React islands (ThemeToggle / MobileMenu) can change tab widths post-hydration.
  const ro = new ResizeObserver(schedule)
  document.querySelectorAll('.pf-tab').forEach((el) => ro.observe(el))
</script>
