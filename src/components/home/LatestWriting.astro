---
import Link from '@/components/Link.astro'
import { getCombinedReadingTime, getRecentPosts } from '@/lib/data-utils'
import { formatDate } from '@/lib/utils'
import { Icon } from 'astro-icon/components'

const posts = await getRecentPosts(3)
const items = await Promise.all(
  posts.map(async (post) => ({
    post,
    readTime: await getCombinedReadingTime(post.id),
  })),
)
---

{
  items.length > 0 && (
    <section class="full-bleed bg-secondary/30 border-border/60 border-y">
      <div class="mx-auto w-full max-w-5xl px-[calc(var(--pf-frame)+1.75rem)] py-20 sm:py-24">
        <div
          class="mb-12 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between"
          data-reveal
        >
          <div>
            <p class="text-brand mb-3 text-xs font-semibold tracking-[0.25em] uppercase">
              From the blog
            </p>
            <h2 class="text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
              Latest writing
            </h2>
          </div>
          <Link
            href="/blog"
            class="group text-muted-foreground hover:text-brand inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
          >
            Read all posts
            <Icon
              name="lucide:arrow-right"
              class="size-4 transition-transform duration-300 group-hover:translate-x-1"
            />
          </Link>
        </div>

        <ul class="divide-border/70 flex flex-col divide-y">
          {items.map(({ post, readTime }, i) => (
            <li data-reveal style={`--reveal-delay: ${i * 80}ms;`}>
              <Link
                href={`/${post.collection}/${post.id}`}
                class="group hover:bg-background/60 -mx-4 flex flex-col gap-2 rounded-xl px-4 py-6 transition-colors sm:flex-row sm:items-center sm:justify-between sm:gap-6"
              >
                <div class="min-w-0">
                  <h3 class="group-hover:text-brand truncate text-lg font-semibold transition-colors sm:text-xl">
                    {post.data.title}
                  </h3>
                  <p class="text-muted-foreground mt-1 line-clamp-1 text-sm">
                    {post.data.description}
                  </p>
                  <div class="text-muted-foreground/80 mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs">
                    <span class="flex items-center gap-1">
                      <Icon name="lucide:calendar" class="size-3" />
                      {formatDate(post.data.date)}
                    </span>
                    <span class="flex items-center gap-1">
                      <Icon name="lucide:clock" class="size-3" />
                      {readTime}
                    </span>
                  </div>
                </div>
                <span class="text-muted-foreground group-hover:border-brand group-hover:text-brand hidden size-10 shrink-0 items-center justify-center rounded-full border transition-all group-hover:translate-x-1 sm:flex">
                  <Icon name="lucide:arrow-right" class="size-4" />
                </span>
              </Link>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}
